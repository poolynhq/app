EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Marketing-only web deploy (e.g. Vercel): landing + waitlist only; blocks /sign-up, /start, /join-org, /business-sign-up.
# EXPO_PUBLIC_MARKETING_WEB_ONLY=1
# Or block sign-up only on specific hostnames (comma-separated), without flagging the whole web build:
# EXPO_PUBLIC_SIGNUP_DISABLED_HOSTS=your-project.vercel.app,www.example.com
# Optional: absolute redirect URL for password reset emails (must be listed in Supabase Auth URL config).
# If unset, the app uses expo-linking with scheme poolyn, e.g. poolyn:///(auth)/reset-password
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://your-app.example/reset-password
# Platform operator UI: docs/SUPER_ADMIN.md (no extra env vars; grant via SQL platform_super_admins)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...your-mapbox-public-token
# Dev / QA only: skip weekday departure alignment in Discover commute matching so you can test
# geometry and reservations without lining up 7:30-style schedules. Do not ship production builds with this set.
# EXPO_PUBLIC_POOLYN_IGNORE_COMMUTE_SCHEDULE=1
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_POOLYN_IGNORE_COMMUTE_SCHEDULE=1